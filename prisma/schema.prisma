// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Required Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application Models
enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials provider
  phone         String?
  state         String?
  region        String?
  landSize      String?
  cropDetails   String?
  latitude      Float?
  longitude     Float?
  role          Role      @default(USER)
  mustChangePassword Boolean @default(false)
  accounts      Account[]
  sessions      Session[]
  
  // Relations for Community Feature
  posts         Post[]
  comments      Comment[]
}

model Post {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  category  String    @default("general")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  authorId  String
  postId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Scheme {
  id                 String   @id @default(cuid())
  title              String
  slug               String?  @unique
  description        String   @db.Text
  benefits           String?  @db.Text
  eligibility        String?  @db.Text
  applicationProcess String?  @db.Text
  documentsRequired  String?  @db.Text
  level              String?  @default("Central") // State/Central
  category           String?  // scheme_category
  tags               String?  // comma separated tags
  state              String   @default("All India")
  link               String?
  deadline           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
